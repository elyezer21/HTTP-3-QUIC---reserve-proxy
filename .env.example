# Dominio publico del sistema. Para pruebas locales o demo sin dominio
# real, dejar "localhost" (Caddy generara un certificado autofirmado).
DOMAIN=localhost

# Host y puerto del servicio de API REST (nombre del servicio en
# docker-compose + puerto interno en el que escucha).
API_REST_UPSTREAM=api-rest:3000

# Host y puerto del servidor de WebSockets (notificaciones en tiempo real).
WEBSOCKET_UPSTREAM=websocket-server:8765

# Host y puerto del frontend de la libreria (pagina web, equipo 1).
FRONTEND_UPSTREAM=frontend:8080
